# 微信支付（Native / PC 扫码充值）配置模板。
# 真实配置请复制为 config/wechatpay.env；该文件与 config/certs/ 均已 gitignore。

# 账户中心 -> 商户信息
WECHATPAY_MCHID=

# 已认证并与商户号绑定的服务号/公众号 AppID
WECHATPAY_APPID=

# 账户中心 -> API安全 -> APIv3密钥（自设 32 位，平台不回显）
WECHATPAY_APIV3_KEY=

# 账户中心 -> API安全 -> API证书序列号（请求签名用）
WECHATPAY_CERT_SERIAL_NO=

# 商户私钥与微信支付公钥文件路径；默认相对仓库根目录。
WECHATPAY_PRIVATE_KEY_PATH=config/certs/apiclient_key.pem
WECHATPAY_PUBLIC_KEY_PATH=config/certs/pub_key.pem

# 账户中心 -> API安全 -> 微信支付公钥 ID（形如 PUB_KEY_ID_xxx）
WECHATPAY_PUBLIC_KEY_ID=

# 商户平台「产品中心 -> 开发配置」中配置的支付结果通知地址。
WECHATPAY_NOTIFY_URL=https://stars-page.com/api/billing/wechat/notify
