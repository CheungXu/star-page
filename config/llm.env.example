# LLM 配置模板（多模型）。
# 复制为 config/llm.env 后填写真实 API Key；config/*.env 已被忽略，不要提交真实 llm.env。
#
# 模型"目录"（非密钥：base_url / model / 参数 / extra_body）维护在可提交的
# config/llm.models.json；本文件只放密钥与基建参数。
# 每个模型在 llm.models.json 里用 api_key_env 指定从哪个变量取密钥。

# 各模型密钥（变量名需与 llm.models.json 中的 api_key_env 对应）。
# 阿里云百炼 / DashScope（qwen）：
QWEN_API_KEY=
# 火山方舟 ARK（doubao）：
ARK_API_KEY=

# 兼容旧单模型变量：未配 QWEN_API_KEY 时，qwen 会回退到 LLM_API_KEY。
LLM_API_KEY=

# 共享基建参数（所有模型通用）。
LLM_TIMEOUT_MS=60000
LLM_MAX_TOKENS=8192
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_INITIAL_DELAY_MS=800
LLM_RETRY_MAX_DELAY_MS=5000

# 可选：覆盖默认勾选的模型（逗号分隔）。不填则用 llm.models.json 的 default_models。
# LLM_DEFAULT_MODELS=qwen,doubao
# 可选：自定义模型目录文件路径。
# LLM_MODELS_FILE=config/llm.models.json
