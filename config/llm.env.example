# LLM 配置模板。
# 复制为 config/llm.env 后填写真实 API Key；config/*.env 已被忽略，不要提交真实 llm.env。

# 阿里云百炼 Qwen 使用 OpenAI-compatible 协议。
LLM_PROVIDER=qwen
LLM_PROTOCOL=openai
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 按阿里云百炼控制台实际可用模型名填写。
LLM_MODEL=qwen3.7-max

# DashScope / 百炼 API Key 写在这里，不要写入示例文件或提交到 Git。
LLM_API_KEY=

# Qwen 深度思考开关，会作为 enable_thinking 合并到 OpenAI-compatible 请求体。
LLM_ENABLE_THINKING=true

LLM_TIMEOUT_MS=60000

# 给其他 OpenAI-compatible 后端预留的扩展请求体，必须是 JSON 对象。
# 示例：{"enable_thinking":true}
LLM_OPENAI_EXTRA_BODY_JSON=
