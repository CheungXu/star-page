# 应用运行环境变量模板。
# 真实密钥只放在 config/.env 或 config/*.env，不要写入本模板，也不要提交真实 .env。

APP_ENV=production
PUBLIC_BASE_URL=http://localhost
FRONTEND_ORIGIN=http://localhost

# 服务端口，公网只开放 22/80/443，3000/8000 只绑定本机或 Docker 内部网络。
FRONTEND_PORT=3000
BACKEND_PORT=8000

# 对象存储
OBJECT_STORAGE_PROVIDER=aliyun
OBJECT_STORAGE_BUCKET=stars-page-demo
OBJECT_STORAGE_REGION=cn-guangzhou
OBJECT_STORAGE_ENDPOINT=oss-cn-guangzhou.aliyuncs.com
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_ACCESS_KEY_SECRET=
# 本地开发可临时使用 local provider。
LOCAL_STORAGE_DIR=data/generated-pages

# 镜像仓库
CONTAINER_REGISTRY=crpi-6w1a91eyh3y1vcd9.cn-guangzhou.personal.cr.aliyuncs.com
CONTAINER_IMAGE=crpi-6w1a91eyh3y1vcd9.cn-guangzhou.personal.cr.aliyuncs.com/stars-page-demo/stars-page-demo

# 数据库
DATABASE_URL=
PGHOST=
PGPORT=5432
PGDATABASE=stars_page
PGUSER=
PGPASSWORD=

# 当前 Demo 默认用户
DEFAULT_USER_NAME=default_test
DEFAULT_USER_EMAIL=default_test@example.local
DEFAULT_USER_DISPLAY_NAME=默认测试用户

# 登录态，后续实现真实登录后启用。
SESSION_SECRET=

# LLM 模型
# LLM_PROTOCOL 当前 Python 后端先支持 openai。
LLM_PROVIDER=qwen
LLM_PROTOCOL=openai
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_MS=60000
LLM_ENABLE_THINKING=true
LLM_OPENAI_EXTRA_BODY_JSON=
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7

# 邮件服务，后续实现注册登录后启用。
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_API_KEY=
