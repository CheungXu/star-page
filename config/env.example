# 应用运行环境变量模板。
# 真实密钥只放在 config/.env 或 config/*.env，不要写入本模板，也不要提交真实 .env。

APP_ENV=production
PUBLIC_BASE_URL=http://localhost
FRONTEND_ORIGIN=http://localhost

# 服务端口，公网只开放 22/80/443，3000/8000 只绑定本机或 Docker 内部网络。
FRONTEND_PORT=3000
BACKEND_PORT=8000

# 对象存储
OBJECT_STORAGE_PROVIDER=aliyun
OBJECT_STORAGE_BUCKET=stars-page-demo
OBJECT_STORAGE_REGION=cn-guangzhou
OBJECT_STORAGE_ENDPOINT=oss-cn-guangzhou.aliyuncs.com
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_ACCESS_KEY_SECRET=
# 本地开发可临时使用 local provider。
LOCAL_STORAGE_DIR=data/generated-pages

# 镜像仓库
CONTAINER_REGISTRY=crpi-6w1a91eyh3y1vcd9.cn-guangzhou.personal.cr.aliyuncs.com
CONTAINER_IMAGE=crpi-6w1a91eyh3y1vcd9.cn-guangzhou.personal.cr.aliyuncs.com/stars-page/stars-page

# 数据库
DATABASE_URL=
PGHOST=
PGPORT=5432
PGDATABASE=stars_page
PGUSER=
PGPASSWORD=

# 手机号用户系统与登录态
AUTH_SESSION_COOKIE_NAME=sp_session
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_COOKIE_SECURE=false
AUTH_SECRET_KEY=

# 短信验证码
SMS_PROVIDER=mock
SMS_CODE_TTL_SECONDS=300
SMS_SEND_COOLDOWN_SECONDS=60
SMS_DAILY_LIMIT_PER_PHONE=20
SMS_DAILY_LIMIT_PER_IP=100
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# LLM 多模型
# 模型目录（base_url/model/参数/extra_body）维护在可提交的 config/llm.models.json；
# 这里只放密钥与基建参数。各模型密钥变量名需与 llm.models.json 的 api_key_env 对应。
QWEN_API_KEY=
ARK_API_KEY=
# 兼容旧单模型变量：未配 QWEN_API_KEY 时 qwen 回退到 LLM_API_KEY。
LLM_API_KEY=
LLM_TIMEOUT_MS=60000
LLM_MAX_TOKENS=8192
LLM_RETRY_ATTEMPTS=3
# 可选：覆盖默认勾选模型（逗号分隔），不填用 llm.models.json 的 default_models。
# LLM_DEFAULT_MODELS=qwen,doubao
# 可选：自定义模型目录路径。
# LLM_MODELS_FILE=config/llm.models.json

# 网页制作技能（page-skills）
# 默认开启；用户未手动选择技能时，由模型自动路由匹配一个技能并注入生成提示。
# PAGE_SKILLS_ENABLED=true
# 技能目录（相对路径会从运行目录逐级向上查找；部署时可指向容器内绝对路径）。
# PAGE_SKILLS_DIR=skills/page-skills
# 技能路由使用的模型 key（对应 llm.models.json 的 key），留空则复用默认模型。
# SKILL_ROUTER_MODEL=

# 邮件服务，后续如需邮箱能力再启用。
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_API_KEY=
