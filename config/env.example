# 应用运行环境变量模板。
# 真实密钥只放在 config/.env，不要写入本模板，也不要提交真实 .env。

NODE_ENV=production

# 对象存储
OBJECT_STORAGE_PROVIDER=aliyun
OBJECT_STORAGE_BUCKET=stars-page-demo
OBJECT_STORAGE_REGION=cn-guangzhou
OBJECT_STORAGE_ENDPOINT=oss-cn-guangzhou.aliyuncs.com
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_ACCESS_KEY_SECRET=

# 镜像仓库
CONTAINER_REGISTRY=crpi-6w1a91eyh3y1vcd9.cn-guangzhou.personal.cr.aliyuncs.com
CONTAINER_IMAGE=crpi-6w1a91eyh3y1vcd9.cn-guangzhou.personal.cr.aliyuncs.com/stars-page-demo/stars-page-demo

# 数据库
DATABASE_URL=

# 登录态
SESSION_SECRET=

# LLM 模型
# LLM_PROTOCOL 当前支持 openai 或 anthropic。
LLM_PROVIDER=
LLM_PROTOCOL=
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_MS=60000
LLM_ANTHROPIC_VERSION=2023-06-01
LLM_ENABLE_THINKING=
LLM_OPENAI_EXTRA_BODY_JSON=

# 邮件服务
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_API_KEY=
